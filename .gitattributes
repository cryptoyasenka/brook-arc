# Normalize all text to LF in the repo and working tree.
# Without this, core.autocrlf=true on Windows makes every .sol/.ts file
# show as "modified" (pure line-ending churn, zero content change).
* text=auto eol=lf

# Binary assets — never touch line endings.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.svg  text eol=lf
*.woff  binary
*.woff2 binary
*.ttf  binary
*.mp4  binary
*.pdf  binary
