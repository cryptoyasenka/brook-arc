# Brook deploy environment template
# Copy to .env and fill in the values. Real .env is gitignored.

# Arc testnet RPC (already aliased in foundry.toml as arc_testnet)
ARC_TESTNET_RPC=https://rpc.testnet.arc.network

# Hex-encoded private key of the deployer wallet. Must hold Arc USDC for gas.
# Recommendation: dedicated deployer (zero history = clean proof of authorship).
DEPLOYER_PRIVATE_KEY=

# USDC ERC-20 on Arc testnet. Override only for local/staging forks.
USDC_ADDRESS=0x3600000000000000000000000000000000000000

# Arcscan verifier API key (optional — leave empty for first deploy if not yet provisioned)
ARCSCAN_API_KEY=

# Set to 1 to enable T17 fork test (default: skipped)
# ARC_FORK=1
